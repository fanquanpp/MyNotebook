{
  "files.encoding": "utf8",
  "files.autoGuessEncoding": true,
  "files.eol": "\n",
  "[markdown]": {
    "files.encoding": "utf8",
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "files.exclude": {
    "**/*.rpyc": true,
    "**/*.rpa": true,
    "**/*.rpymc": true,
    "**/cache/": true
  },
  "markdown.validate.enabled": true
}
