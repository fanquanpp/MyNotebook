# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Markdown files
[*.md]
charset = utf-8
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# PowerShell scripts
[*.ps1]
charset = utf-8
indent_style = space
indent_size = 4

# Shell scripts
[*.sh]
charset = utf-8
indent_style = space
indent_size = 4

# JSON/YAML
[*.json]
charset = utf-8
indent_style = space
indent_size = 2

[*.{yml,yaml}]
charset = utf-8
indent_style = space
indent_size = 2

# Code files
[*.{c,cpp,h,hpp,java,py,js,ts,tsx,vue,sql,lua,rpy}]
charset = utf-8
indent_style = space
indent_size = 4

# Git files
[.gitignore]
charset = utf-8

# VS Code settings
[.vscode/*.json]
charset = utf-8
indent_style = space
indent_size = 2
