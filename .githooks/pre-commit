#!/bin/sh
#
# Pre-commit hook for MyNotebook
# Automatically checks encoding and formats Markdown
#

echo "Running pre-commit checks..."

# Get the script directory
HOOKS_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$HOOKS_DIR/../.." && pwd)"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Counters
ERRORS=0
WARNINGS=0

# Check encoding of Markdown files
echo "${YELLOW}Checking file encoding...${NC}"

# Get list of staged Markdown files
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(md|MD)$')

if [ -n "$STAGED_MD_FILES" ]; then
    for file in $STAGED_MD_FILES; do
        FULL_PATH="$PROJECT_ROOT/$file"

        if [ -f "$FULL_PATH" ]; then
            # Check for BOM
            BOM=$(head -c 3 "$FULL_PATH" | od -An -tx1)
            if [ "$BOM" = " ef bb bf" ]; then
                echo "${RED}ERROR: $file has UTF-8 BOM${NC}"
                echo "  Use: .scripts/validate_encoding.ps1 -Fix"
                ERRORS=$((ERRORS + 1))
            fi

            # Check for garbled characters
            if grep -q 'ï¼\|ä¸\|é€\|å›\|ä»\|ä½\|æˆ\|åœ\|æ˜\|è¿\|æ–\|çš' "$FULL_PATH" 2>/dev/null; then
                echo "${RED}ERROR: $file contains garbled characters${NC}"
                echo "  Use: .scripts/validate_encoding.ps1 -Fix"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    done
fi

# Check file naming conventions
echo "${YELLOW}Checking file naming conventions...${NC}"

if [ -n "$STAGED_MD_FILES" ]; then
    for file in $STAGED_MD_FILES; do
        FILENAME=$(basename "$file")

        # Skip README.md files
        if [ "$FILENAME" = "README.md" ]; then
            continue
        fi

        # Check naming pattern: C/G/V + 2-digit module number + _ + 3-digit file number + - + description
        if ! echo "$FILENAME" | grep -qE '^(C|G|V)[0-9]{2}_[0-9]{3}-.+\.md$'; then
            echo "${YELLOW}WARNING: $file does not follow naming convention${NC}"
            echo "  Expected: C01_101-description.md, G01_201-description.md, or V01_101-description.md"
            WARNINGS=$((WARNINGS + 1))
        fi
    done
fi

# Summary
echo ""
echo "=============================================="
if [ $ERRORS -gt 0 ]; then
    echo "${RED}Pre-commit check FAILED${NC}"
    echo "${RED}Errors: $ERRORS${NC}"
    if [ $WARNINGS -gt 0 ]; then
        echo "${YELLOW}Warnings: $WARNINGS${NC}"
    fi
    echo ""
    echo "Please fix the errors before committing."
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo "${YELLOW}Pre-commit check passed with warnings${NC}"
    echo "${YELLOW}Warnings: $WARNINGS${NC}"
    echo "${GREEN}Commit allowed but please review warnings.${NC}"
    exit 0
else
    echo "${GREEN}Pre-commit check passed!${NC}"
    echo "All files are valid."
    exit 0
fi